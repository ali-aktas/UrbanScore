<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/pro_subscription"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <!-- Header Image -->
    <ImageView
        android:id="@+id/ivProHeader"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/loginicon2"
        android:contentDescription="Pro subscription"
        app:layout_constraintTop_toBottomOf="@id/toolbarLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Pro Title -->
    <TextView
        android:id="@+id/tvProTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pro_title"
        android:textColor="@color/auth_accent"
        android:textSize="28sp"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivProHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Pro Description -->
    <TextView
        android:id="@+id/tvProDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pro_description"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/roboto_medium"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvProTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvProDescription"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subscription Options Container -->
    <LinearLayout
        android:id="@+id/subscriptionOptionsLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvProDescription"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Subscription Plan Cards -->
        <RadioGroup
            android:id="@+id/subscriptionRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Monthly Plan Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMonthlyPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/auth_accent"
                android:checkable="true">

                <RadioButton
                    android:id="@+id/radioMonthly"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Plan"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/auth_accent" />

                    <TextView
                        android:id="@+id/tvMonthlyPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading price..."
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• No ads\n• Full access to all features\n• Pay monthly"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Yearly Plan Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardYearlyPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="#80FFFFFF"
                android:checkable="true">

                <RadioButton
                    android:id="@+id/radioYearly"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yearly Plan"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/auth_accent" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvYearlyPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading price..."
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tvSavings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" (Save 20%)"
                            android:textSize="16sp"
                            android:textStyle="italic"
                            android:textColor="#4CAF50"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• No ads\n• Full access to all features\n• Pay once for a full year\n• Best value"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </RadioGroup>

        <!-- Subscribe Button -->
        <Button
            android:id="@+id/btnSubscribe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subscribe Now"
            android:textAllCaps="false"
            android:backgroundTint="@color/auth_accent"
            android:fontFamily="@font/poppins_medium"
            android:padding="12dp"
            android:layout_marginTop="16dp"/>

        <!-- Restore Purchases Button -->
        <Button
            android:id="@+id/btnRestorePurchases"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Purchases"
            android:textAllCaps="false"
            android:background="?attr/selectableItemBackground"
            android:textColor="@color/auth_accent"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginTop="8dp" />

        <!-- Legal Disclaimer -->
        <TextView
            android:id="@+id/tvLegalDisclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="By subscribing, you agree to our Terms of Service. Your subscription automatically renews unless auto-renew is turned off at least 24 hours before the end of the current period. Your account will be charged for renewal within 24 hours prior to the end of the current period."
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:fontFamily="@font/montserrat_light" />

        <TextView
            android:id="@+id/tvPrivacyPolicy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Privacy Policy"
            android:textColor="@color/auth_accent"
            android:textSize="12sp"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium" />
    </LinearLayout>

    <!-- Pro Status Layout (Shown when user is already Pro) -->
    <LinearLayout
        android:id="@+id/proStatusLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvProDescription"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_check"
            android:contentDescription="Pro active"
            app:tint="@color/auth_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pro_active"
            android:textColor="@color/auth_accent"
            android:textSize="24sp"
            android:fontFamily="@font/poppins_bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvExpiryDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subscription_expiry"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/roboto_medium"
            android:layout_marginTop="8dp"
            tools:text="Your subscription expires on 18 Apr 2025" />

        <Button
            android:id="@+id/btnRestoreProPurchases"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Restore Purchases"
            android:textAllCaps="false"
            android:background="?attr/selectableItemBackground"
            android:textColor="@color/auth_accent"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnManageSubscription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage Subscription"
            android:textAllCaps="false"
            android:backgroundTint="#F44336"
            android:textColor="@color/white"
            android:layout_marginTop="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>